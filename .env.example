# ─── Database ─────────────────────────────────────────────────────────────────
# Neon / any PostgreSQL connection string shared by all agents.
# Legacy DATABASE_CONNECTION_STRING and DATABASE_URL are also accepted.
SAP_AGENTS_DATABASE_URL=postgresql://username:password@host:5432/sap_agents_db?sslmode=require

# ─── SAP Business One Service Layer ───────────────────────────────────────────
SAP_BASE_URL=http://localhost:50000/b1s/v1
SAP_USERNAME=manager
SAP_PASSWORD=password
SAP_COMPANYDB=SBODEMOUS

# ─── Claude LLM (intent parsers, supervisor router, chat response, RAG SQL) ──
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com/v1
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_API_VERSION=2023-06-01
CLAUDE_PROMPT_CACHE=true

# Optional separate Claude keys/models for production isolation by agent/team.
BIG_SUPERVISOR_CLAUDE_API_KEY=
BIG_SUPERVISOR_CLAUDE_MODEL=claude-opus-4-7
PURCHASE_TEAM_CLAUDE_API_KEY=
PURCHASE_TEAM_CLAUDE_MODEL=claude-opus-4-7
SALES_TEAM_CLAUDE_API_KEY=
SALES_TEAM_CLAUDE_MODEL=claude-opus-4-7
SALES_SQL_CLAUDE_API_KEY=
SALES_SQL_CLAUDE_MODEL=claude-opus-4-7
CHAT_RESPONSE_CLAUDE_API_KEY=
CHAT_RESPONSE_CLAUDE_MODEL=claude-opus-4-7

# ─── Purchase RAG (ChromaDB vector store) ────────────────────────────────────
PURCHASE_RAG_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
PURCHASE_RAG_PERSIST_DIR=.rag_chroma/purchase
SALES_RAG_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
SALES_RAG_PERSIST_DIR=.rag_chroma/sales
SALES_RAG_USE_VECTOR=false

# ─── Misc ─────────────────────────────────────────────────────────────────────
# External SAP HANA SQL fetch API used by analytical SELECT queries.
HANA_SQL_API_URL=http://vzone.in:1662/api/GetMethod/GetData
HANA_SQL_API_TOKEN=
HANA_SQL_API_KEY=
HANA_SQL_API_AUTH_SCHEME=Bearer
# Optional JSON object for vendor-specific headers, for example:
# HANA_SQL_API_HEADERS={"x-company-id":"demo","x-api-version":"1"}
HANA_SQL_API_HEADERS=

# Maximum seconds a raw SQL fetch query may run.
SQL_QUERY_TIMEOUT=30
